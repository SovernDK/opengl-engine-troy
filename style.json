        "fontColor": "#000000",
        "fontHoverColor": "#ff0000"
    },

    "mm_window": {
        "backgroundColor": "#ffffff",
        "alpha": 0,
        "childrenOrigin": "center",
        "verticalLayout": {
            "expand": true,
            "fit": true,
            "margin": {
                "left": 6,
                "top": 6,
                "right": 6,
                "bottom": 6
            },
