{
    "root": {
        "backgroundColor": "#ffffff",
        "alpha": 0
    },

    "defWindow": {
        "backgroundColor": "#F5B027",
        "alpha": 255,
        "childrenOrigin": "center",
        "verticalLayout": {
            "expand": true,
            "fit": true,
            "margin": {
                "left": 6,
                "top": 6,
                "right": 6,
                "bottom": 6
            },
            "spacing": 10
        }
    },

    "topbar": {
        "backgroundColor": "#FDEDC9",
        "alpha": 255,
        "dropShadow": true,
        "shadowOffset": {
            "x": 2,
            "y": 2
        },
        "horizontalLayout": {
            "expand": true,
            "fit": true,
            "margin": {
                "left": 6,
                "top": 6,
                "right": 6,
                "bottom": 6
            },
            "spacing": 10
        }
    },

    "defButton": {
        "backgroundColor": "#FDC354",
        "alpha": 255,
        "hoverColor": "#ffffff",
        "dropShadow": true,
        "shadowOffset": {
            "x": 2,
            "y": 2
        },

        "fontName": "default",
        "fontSize": 64,
        "fontColor": "#ffffff",
        "fontHoverColor": "#ff0000"
    },

    "defImage": {
        "backgroundColor": "#ffffff",
        "alpha": 0,
        "hoverColor": "#ffffff"
    },

    "defText": {
        "backgroundColor": "#ffffff",
        "alpha": 0,
